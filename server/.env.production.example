# Copy to server/.env before running infra/docker-compose.prod.yml.

POSTGRES_USER=cove
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=cove

MINIO_ROOT_USER=cove
MINIO_ROOT_PASSWORD=change-this-minio-password

APP_JWT_SECRET=change-this-to-a-random-64-character-secret-value
APP_CORS_ALLOWED_ORIGINS=https://cove.greatshiftai.com,https://cove-cb2.pages.dev
APP_EMAIL_PROVIDER=smtp
APP_EMAIL_FROM=Cove <no-reply@greatshiftai.com>

# Use a real SMTP provider for email OTP in production.
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=replace-me
SPRING_MAIL_PASSWORD=replace-me
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true

# Phone OTP stays mocked unless Twilio is configured.
APP_SMS_PROVIDER=mock
APP_SMS_TWILIO_ACCOUNT_SID=
APP_SMS_TWILIO_AUTH_TOKEN=
APP_SMS_TWILIO_FROM_NUMBER=

# Optional web push notifications.
APP_PUSH_VAPID_PUBLIC_KEY=
APP_PUSH_VAPID_PRIVATE_KEY=
APP_PUSH_SUBJECT=mailto:no-reply@greatshiftai.com
